# ── Core ───────────────────────────────────────────────────────────────────
# Local Postgres usually needs ?sslmode=disable; managed Postgres does not.
DB_URL="postgres://username:password@localhost:5432/katana_id?sslmode=disable"
PORT="8080"
ALLOWED_ORIGINS="http://localhost:5173"

# Base URL of this server; must exactly match the redirect URI registered with
# each OAuth provider (SERVER_URL + /auth/google/callback, etc.). Use http for
# local dev — auth cookies drop their Secure flag automatically off https.
SERVER_URL="http://localhost:8080"
# Base URL of the frontend; OAuth flows redirect here after sign-in.
FRONTEND_URL="http://localhost:5173"

# ── Email (OTP sign-in) ──────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Gemini (AI brand generation) ─────────────────────────────────────────────
# https://aistudio.google.com/apikey  — optional; without it the server falls
# back to a local name generator.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"

# ── OAuth providers ──────────────────────────────────────────────────────────
# Google  (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub  (github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Optional check providers ─────────────────────────────────────────────────
# GITHUB_TOKEN raises the GitHub API rate limit from 60 to 5000 req/hr.
GITHUB_TOKEN=""
# TWITTER_BEARER_TOKEN enables the X/Twitter handle check.
TWITTER_BEARER_TOKEN=""
# BRAVE_API_KEY enables the search-competitiveness check (brave.com/search/api).
BRAVE_API_KEY=""
